# Runtime
NODE_ENV=production
PORT=9997
CLIENT_ORIGIN=https://chat.evaonline.ir

# Authentication
# Replace this with a long random value before deployment.
JWT_SECRET=replace-with-a-long-random-secret
SESSION_TTL_DAYS=60

# Storage
DATABASE_PATH=/app/data/verdant.db
UPLOAD_DIR=/app/storage/uploads
MAX_FILE_SIZE_MB=50

# Data retention
MESSAGE_RETENTION_DAYS=30
FILE_RETENTION_DAYS=7
HIDDEN_CHAT_DELETE_DAYS=7
