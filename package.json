{
  "name": "verdant-chat",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "preinstall": "node -e \"const major=Number(process.versions.node.split('.')[0]);if(major!==22){console.error('Verdant Chat requires Node.js 22.x. Current: '+process.version);process.exit(1)}\"",
    "dev": "concurrently -n server,client-v2 -c auto \"npm run dev -w @verdant/server\" \"npm run dev -w @verdant/client-v2\"",
    "dev:legacy": "concurrently -n server,client -c auto \"npm run dev -w @verdant/server\" \"npm run dev -w @verdant/client\"",
    "build": "npm run build -w @verdant/client-v2",
    "build:legacy": "npm run build -w @verdant/client",
    "start": "npm run start -w @verdant/server",
    "db:generate": "npm run db:generate -w @verdant/server",
    "electron:build": "npm run electron:build -w @verdant/client-v2",
    "android:sync": "npm run android:sync -w @verdant/client"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "engines": {
    "node": "22.x",
    "npm": ">=10 <12"
  }
}
